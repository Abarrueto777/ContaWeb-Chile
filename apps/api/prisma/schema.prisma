generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolUsuario {
  ADMIN
  CONTADOR
  VISOR
}

enum TipoDocumento {
  BOLETA_ELECTRONICA
  FACTURA_ELECTRONICA
  NOTA_CREDITO
  NOTA_DEBITO
}

enum EstadoDocumento {
  BORRADOR
  EMITIDO
  ACEPTADO_SII
  RECHAZADO_SII
  ANULADO
}

enum TipoCuenta {
  ACTIVO
  PASIVO
  PATRIMONIO
  INGRESO
  GASTO
}

enum NaturalezaCuenta {
  DEUDORA
  ACREEDORA
}

enum EstadoAsiento {
  BORRADOR
  CONTABILIZADO
}

enum TipoDocCompra {
  FACTURA
  NOTA_CREDITO
  LIQUIDACION_FACTURA
}

enum CondicionPago {
  CONTADO
  CREDITO
}

enum TipoImpuesto {
  NINGUNO
  BEBIDAS_20
  BEBIDAS_31
  LUJO
  CARNE
  HARINA
  DIESEL
}

enum TipoAFP {
  CAPITAL
  CUPRUM
  HABITAT
  PLANVITAL
  PROVIDA
  MODELO
  UNO
}

enum TipoTrabajador {
  DEPENDIENTE
  SUELDO_EMPRESARIAL
}

enum TipoGratificacion {
  ART_50
  ART_50_LIBRE
  ART_47
  NINGUNA
}

enum TipoContrato {
  INDEFINIDO
  PLAZO_FIJO
  OBRA_FAENA
}

enum TipoMovimientoBanco {
  COBRO_CLIENTE
  PAGO_PROVEEDOR
  PAGO_IVA
  PAGO_PPM
  PAGO_REMUNERACIONES
  PAGO_HONORARIO
  TRANSFERENCIA
  COMISION_BANCO
  INTERES_BANCO
  INTERES_GANADO
  RETIRO_DUENO
  APORTE_CAPITAL
  GASTO_GENERAL
  OTRO
}

enum CategoriaActivo {
  MAQUINARIA
  VEHICULO
  MUEBLES
  EQUIPOS_COMPUTACION
  CONSTRUCCION
  TERRENO
  OTRO
}

enum TipoVacacion {
  NORMAL
  PROGRESIVO
  COLECTIVO
}

enum EstadoVacacion {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum TipoPermiso {
  MATRIMONIO
  UNION_CIVIL
  FALLECIMIENTO
  SIN_GOCE
  ADMINISTRATIVO
  OTRO
}

enum TipoLicencia {
  COMUN
  ACCIDENTE_LABORAL
  PRENATAL
  POSTNATAL
  MENTAL
}

enum TipoRentaRetiro {
  AFECTA
  EXENTA
  NO_RENTA
}

enum TipoBienRP {
  AGRICOLA
  TRANSPORTE
}

enum EstadoUsuario {
  ACTIVO
  SUSPENDIDO
}

model Usuario {
  id        String        @id @default(cuid())
  email     String        @unique
  nombre    String
  password  String
  rol       RolUsuario    @default(CONTADOR)
  estado    EstadoUsuario @default(ACTIVO)
  emailVerificado   Boolean   @default(false)
  resetTokenHash    String?
  resetTokenExpiry  DateTime?
  verifyTokenHash   String?
  verifyTokenExpiry DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  empresas  Empresa[]

  @@map("usuarios")
}

model Empresa {
  id                 String                @id @default(cuid())
  rut                String                @unique
  razonSocial        String
  giro               String
  actividadEconomica String?
  direccion          String?
  telefono           String?
  email              String?
  ppmRate               Decimal               @default(0.0020) @db.Decimal(6, 4)
  representanteLegal    String?
  rutRepresentante      String?
  tasaRetencionHon      Decimal               @default(10.75) @db.Decimal(5, 2)
  usuarioId          String
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  usuario            Usuario               @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  clientes           Cliente[]
  documentos         DocumentoTributario[]
  cuentas            CuentaContable[]
  asientos           AsientoContable[]
  facturasRecibidas  FacturaRecibida[]
  honorarios         Honorario[]
  cuentasBancarias   CuentaBancaria[]
  movimientosBanco   MovimientoBanco[]
  trabajadores       Trabajador[]
  liquidaciones      Liquidacion[]
  activosFijos       ActivoFijo[]
  finiquitos         Finiquito[]
  configEmpresa      ConfigEmpresa[]
  vacaciones         Vacacion[]
  permisos           Permiso[]
  licencias          LicenciaMedica[]
  socios             Socio[]
  retiros            Retiro[]
  rpBienes           RPBien[]
  rpPpm              RPPpm[]

  @@map("empresas")
}

model Cliente {
  id         String                @id @default(cuid())
  empresaId  String
  rut        String
  nombre     String
  email      String?
  telefono   String?
  direccion  String?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  empresa    Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  documentos DocumentoTributario[]

  @@unique([empresaId, rut])
  @@map("clientes")
}

model DocumentoTributario {
  id        String          @id @default(cuid())
  empresaId String
  clienteId String?
  tipo      TipoDocumento
  folio     Int
  estado    EstadoDocumento @default(BORRADOR)
  fecha     DateTime        @default(now())
  neto      Decimal         @db.Decimal(19, 4)
  iva       Decimal         @db.Decimal(19, 4)
  total     Decimal         @db.Decimal(19, 4)
  glosa     String?
  condicionPago CondicionPago @default(CONTADO)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  empresa   Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente   Cliente?        @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  lineas    LineaDocumento[]
  asientos  AsientoContable[]

  @@unique([empresaId, tipo, folio])
  @@map("documentos_tributarios")
}

model LineaDocumento {
  id             String              @id @default(cuid())
  documentoId    String
  descripcion    String
  cantidad       Decimal             @db.Decimal(19, 4)
  precioUnitario Decimal             @db.Decimal(19, 4)
  descuento      Decimal             @default(0) @db.Decimal(19, 4)
  subtotal       Decimal             @db.Decimal(19, 4)
  documento      DocumentoTributario @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  @@map("lineas_documento")
}

model CuentaContable {
  id                 String           @id @default(cuid())
  empresaId          String
  codigo             String
  nombre             String
  tipo               TipoCuenta
  naturaleza         NaturalezaCuenta
  nivel              Int
  cuentaPadreId      String?
  permiteMovimientos Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  empresa            Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cuentaPadre        CuentaContable?  @relation("CuentaHijos", fields: [cuentaPadreId], references: [id], onDelete: SetNull)
  cuentasHijo        CuentaContable[] @relation("CuentaHijos")
  lineasAsiento      LineaAsiento[]

  @@unique([empresaId, codigo])
  @@map("cuentas_contables")
}

model AsientoContable {
  id          String               @id @default(cuid())
  empresaId   String
  documentoId String?
  numero      Int
  fecha       DateTime
  glosa       String
  estado      EstadoAsiento        @default(BORRADOR)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  empresa     Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  documento   DocumentoTributario? @relation(fields: [documentoId], references: [id], onDelete: SetNull)
  lineas      LineaAsiento[]

  @@unique([empresaId, numero])
  @@map("asientos_contables")
}

model FacturaRecibida {
  id              String        @id @default(cuid())
  empresaId       String
  proveedorRut    String
  proveedorNombre String
  tipo            TipoDocCompra @default(FACTURA)
  folio           Int
  fecha           DateTime
  neto            Decimal       @db.Decimal(19, 4)
  iva             Decimal       @db.Decimal(19, 4)
  impAdicional    Decimal       @default(0) @db.Decimal(19, 4)
  retencion       Decimal       @default(0) @db.Decimal(19, 4)
  total           Decimal       @db.Decimal(19, 4)
  tipoImpuesto    TipoImpuesto  @default(NINGUNO)
  glosa           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  empresa         Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, proveedorRut, tipo, folio])
  @@map("facturas_recibidas")
}

model Honorario {
  id              String   @id @default(cuid())
  empresaId       String
  prestadorRut    String
  prestadorNombre String
  folio           Int
  fecha           DateTime
  monto           Decimal  @db.Decimal(19, 4)
  retencion       Decimal  @db.Decimal(19, 4)
  retiene         Boolean  @default(true)
  glosa           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  empresa         Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("honorarios")
}

model LineaAsiento {
  id        String          @id @default(cuid())
  asientoId String
  cuentaId  String
  debe      Decimal         @default(0) @db.Decimal(19, 4)
  haber     Decimal         @default(0) @db.Decimal(19, 4)
  glosa     String?
  asiento   AsientoContable @relation(fields: [asientoId], references: [id], onDelete: Cascade)
  cuenta    CuentaContable  @relation(fields: [cuentaId], references: [id], onDelete: Cascade)

  @@map("lineas_asiento")
}

model CuentaBancaria {
  id           String            @id @default(cuid())
  empresaId    String
  banco        String
  tipoCuenta   String            @default("CORRIENTE")
  numero       String
  saldoInicial Decimal           @default(0) @db.Decimal(19, 4)
  moneda       String            @default("CLP")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  empresa      Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  movimientos  MovimientoBanco[]

  @@unique([empresaId, banco, numero])
  @@map("cuentas_bancarias")
}

model MovimientoBanco {
  id          String              @id @default(cuid())
  empresaId   String
  cuentaId    String
  fecha       DateTime
  descripcion String
  cargo       Decimal             @default(0) @db.Decimal(19, 4)
  abono       Decimal             @default(0) @db.Decimal(19, 4)
  saldo       Decimal             @db.Decimal(19, 4)
  tipo        TipoMovimientoBanco @default(OTRO)
  conciliado  Boolean             @default(false)
  glosa       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  empresa     Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cuenta      CuentaBancaria      @relation(fields: [cuentaId], references: [id], onDelete: Cascade)

  @@map("movimientos_banco")
}

model Trabajador {
  id                String            @id @default(cuid())
  empresaId         String
  rut               String
  nombre            String
  apellidoPaterno   String?
  apellidoMaterno   String?
  sexo              String?
  cargo             String?
  tipo              TipoTrabajador    @default(DEPENDIENTE)
  sueldoBase        Decimal           @db.Decimal(19, 4)
  afp               TipoAFP           @default(HABITAT)
  salud             String            @default("FONASA")
  pctSalud          Decimal           @default(0.07) @db.Decimal(5, 4)
  tieneCes          Boolean           @default(false)
  tipoGratificacion TipoGratificacion @default(ART_50)
  tieneMovilizacion  Boolean           @default(false)
  tieneColacion      Boolean           @default(false)
  tieneConectividad  Boolean           @default(false)
  trabajaFinSemana   Boolean           @default(false)
  cargasFamiliares   Int               @default(0)
  montoMovilizacion Decimal?          @db.Decimal(19, 4)
  montoColacion     Decimal?          @db.Decimal(19, 4)
  email             String?
  montoIsapre       Decimal?          @db.Decimal(10, 4)
  domicilio         String?
  fechaNacimiento   DateTime?
  estadoCivil       String?
  nacionalidad      String?           @default("Chilena")
  region            String?
  comuna            String?
  jornadaHoras      Int               @default(42)
  tipoContrato           TipoContrato      @default(INDEFINIDO)
  fechaTerminoContrato   DateTime?
  fechaIngreso           DateTime
  activo            Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  empresa           Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  liquidaciones     Liquidacion[]
  finiquitos        Finiquito[]
  vacaciones        Vacacion[]
  permisos          Permiso[]
  licencias         LicenciaMedica[]

  @@unique([empresaId, rut])
  @@map("trabajadores")
}

model Finiquito {
  id              String     @id @default(cuid())
  empresaId       String
  trabajadorId    String
  fechaTermino    DateTime
  causal          String
  diasVacaciones  Decimal    @db.Decimal(8, 2)
  montoVacaciones Decimal    @db.Decimal(19, 4)
  aniosServicio   Decimal    @db.Decimal(5, 2)
  indemnizacion   Decimal    @default(0) @db.Decimal(19, 4)
  avisoPrevio     Decimal    @default(0) @db.Decimal(19, 4)
  otrosDescuentos Decimal    @default(0) @db.Decimal(19, 4)
  totalBruto      Decimal    @db.Decimal(19, 4)
  totalNeto       Decimal    @db.Decimal(19, 4)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  empresa         Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  trabajador      Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)

  @@map("finiquitos")
}

model Liquidacion {
  id             String     @id @default(cuid())
  empresaId      String
  trabajadorId   String
  anio           Int
  mes            Int
  sueldoBase     Decimal    @db.Decimal(19, 4)
  horasExtra          Decimal  @default(0) @db.Decimal(19, 4)
  cantHorasExtra      Decimal  @default(0) @db.Decimal(19, 4)
  horasExtraFeriado   Decimal  @default(0) @db.Decimal(19, 4)
  cantHorasExtraFeriado Decimal @default(0) @db.Decimal(19, 4)
  horasDescuento      Decimal  @default(0) @db.Decimal(19, 4)
  otrosDescuentos Decimal   @default(0) @db.Decimal(19, 4)
  bono           Decimal    @default(0) @db.Decimal(19, 4)
  diasTrabajados Int        @default(30)
  imponible      Decimal    @db.Decimal(19, 4)
  cotizAfp       Decimal    @db.Decimal(19, 4)
  cotizSis       Decimal    @db.Decimal(19, 4)
  cotizSalud     Decimal    @db.Decimal(19, 4)
  cotizCes       Decimal    @default(0) @db.Decimal(19, 4)
  impuestoUnico  Decimal    @default(0) @db.Decimal(19, 4)
  gratificacion  Decimal    @default(0) @db.Decimal(19, 4)
  movilizacion   Decimal    @default(0) @db.Decimal(19, 4)
  colacion       Decimal    @default(0) @db.Decimal(19, 4)
  conectividad   Decimal    @default(0) @db.Decimal(19, 4)
  asigFamiliar   Decimal    @default(0) @db.Decimal(19, 4)
  anticipo       Decimal    @default(0) @db.Decimal(19, 4)
  liquido        Decimal    @db.Decimal(19, 4)
  costoEmpleador Decimal    @db.Decimal(19, 4)
  pagada         Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  diasSinGoce    Int        @default(0)
  montoSinGoce   Decimal    @default(0) @db.Decimal(19, 4)
  diasLicenciaMedica Int    @default(0)
  subsidioLm     Decimal    @default(0) @db.Decimal(19, 4)
  empresa        Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  trabajador     Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)

  @@unique([empresaId, trabajadorId, anio, mes])
  @@map("liquidaciones")
}

model ActivoFijo {
  id               String          @id @default(cuid())
  empresaId        String
  nombre           String
  categoria        CategoriaActivo @default(OTRO)
  fechaCompra      DateTime
  costoCompra      Decimal         @db.Decimal(19, 4)
  vidaUtilAnios    Int
  valorResidual    Decimal         @default(0) @db.Decimal(19, 4)
  depreciacionMes  Decimal         @db.Decimal(19, 4)
  acumDepreciacion Decimal         @default(0) @db.Decimal(19, 4)
  activo           Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  empresa          Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("activos_fijos")
}

model ValorUFUTM {
  id           String  @id @default(cuid())
  anio         Int
  mes          Int
  uf           Decimal @db.Decimal(10, 4)
  utm          Decimal @db.Decimal(10, 2)
  imm          Decimal @db.Decimal(10, 2)
  afpCapital      Decimal   @default(0.1144) @db.Decimal(6, 4)
  afpCuprum       Decimal   @default(0.1144) @db.Decimal(6, 4)
  afpHabitat      Decimal   @default(0.1127) @db.Decimal(6, 4)
  afpPlanvital    Decimal   @default(0.1127) @db.Decimal(6, 4)
  afpProvida      Decimal   @default(0.1145) @db.Decimal(6, 4)
  afpModelo       Decimal   @default(0.1077) @db.Decimal(6, 4)
  afpUno          Decimal   @default(0.1049) @db.Decimal(6, 4)
  sisEmpleador    Decimal   @default(0.0162) @db.Decimal(6, 4)
  topeImponibleUf Decimal   @default(90.0)  @db.Decimal(6, 2)
  previredSyncAt  DateTime?

  @@unique([anio, mes])
  @@map("valores_uf_utm")
}

model FactorIpc {
  id     String  @id @default(cuid())
  anio   Int
  mes    Int
  factor Decimal @default(1.0) @db.Decimal(8, 4)

  @@unique([anio, mes])
  @@map("factores_ipc")
}

model ConfigEmpresa {
  id        String  @id @default(cuid())
  empresaId String
  clave     String
  valor     String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, clave])
  @@map("config_empresa")
}

model Vacacion {
  id             String         @id @default(cuid())
  empresaId      String
  trabajadorId   String
  fechaInicio    DateTime
  fechaFin       DateTime
  diasHabiles    Int
  saldoPrevio    Decimal        @db.Decimal(8, 2)
  saldoPosterior Decimal        @db.Decimal(8, 2)
  periodoAnual   String?
  tipo           TipoVacacion   @default(NORMAL)
  estado         EstadoVacacion @default(APROBADA)
  observacion    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  empresa        Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  trabajador     Trabajador     @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)

  @@map("vacaciones")
}

model Permiso {
  id           String      @id @default(cuid())
  empresaId    String
  trabajadorId String
  tipo         TipoPermiso
  fechaInicio  DateTime
  fechaFin     DateTime
  diasHabiles  Int
  conGoce      Boolean     @default(true)
  parentesco   String?
  observacion  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  empresa      Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  trabajador   Trabajador  @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)

  @@map("permisos")
}

model RPBien {
  id            String     @id @default(cuid())
  empresaId     String
  tipo          TipoBienRP
  descripcion   String     @default("")
  rolAvaluo     String?
  municipio     String?
  avaluoFiscal  Decimal    @default(0) @db.Decimal(19, 4)
  anioAvaluo    Int?
  patente       String?
  tipoVehiculo  String?
  marca         String?
  modelo        String?
  anioVehiculo  Int?
  valorTasacion Decimal    @default(0) @db.Decimal(19, 4)
  anioTasacion  Int?
  activo        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  empresa       Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("rp_bienes")
}

model RPPpm {
  id            String    @id @default(cuid())
  empresaId     String
  anio          Int
  mes           Int
  ventasPeriodo Decimal   @default(0) @db.Decimal(19, 4)
  ppmTasa       Decimal   @default(0.0025) @db.Decimal(8, 4)
  ppmMonto      Decimal   @default(0) @db.Decimal(19, 4)
  pagado        Boolean   @default(false)
  fechaPago     DateTime?
  observacion   String    @default("")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  empresa       Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, anio, mes])
  @@map("rp_ppm")
}

model Socio {
  id         String   @id @default(cuid())
  empresaId  String
  rut        String
  nombre     String
  tipo       String   @default("SOCIO")
  porcentaje Decimal  @default(0) @db.Decimal(5, 2)
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  empresa    Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  retiros    Retiro[]

  @@unique([empresaId, rut])
  @@map("socios")
}

model Retiro {
  id             String          @id @default(cuid())
  empresaId      String
  socioId        String
  fecha          DateTime
  monto          Decimal         @db.Decimal(19, 4)
  concepto       String          @default("")
  factorIpc      Decimal         @default(1.0) @db.Decimal(8, 4)
  montoCorregido Decimal         @db.Decimal(19, 4)
  tipoRenta      TipoRentaRetiro @default(AFECTA)
  creditoIdpc    Decimal         @default(0) @db.Decimal(19, 4)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  empresa        Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  socio          Socio           @relation(fields: [socioId], references: [id], onDelete: Cascade)

  @@map("retiros")
}

model LicenciaMedica {
  id             String       @id @default(cuid())
  empresaId      String
  trabajadorId   String
  fechaInicio    DateTime
  fechaFin       DateTime
  tipo           TipoLicencia @default(COMUN)
  numLicencia    String       @default("")
  entidad        String       @default("FONASA")
  diasLicencia   Int          @default(0)
  subsidioMonto  Decimal      @default(0) @db.Decimal(19, 4)
  subsidioPagado Boolean      @default(false)
  notas          String       @default("")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  empresa        Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  trabajador     Trabajador   @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)

  @@map("licencias_medicas")
}
